{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/optimize-route.js": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Permissions-Policy", "value": "camera=(self), geolocation=(self)" }
      ]
    }
  ]
}
